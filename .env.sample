ANTHROPIC_API_KEY=your-anthropic-key-here
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.langsmith.com
LANGSMITH_API_KEY=your-langsmith-api-key-here
LANGSMITH_PROJECT=your-langsmith-project-name-here
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Server-only; used by login/signup to read/update public.users (e.g. password). Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here
# AWS S3 Configuration (for Files)
AWS_REGION=ap-southeast-3
AWS_S3_BUCKET=ai-data-cleanser-files
# Local Postgres via docker-compose (default credentials)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_DB=local_dev
# NextAuth v4 (use same value for both if migrating from v5)
NEXTAUTH_SECRET=your-auth-secret-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
BIGQUERY_DEFAULT_CONNECTION_STRING=your-conn-string-here-base64-encoded
BIGQUERY_DEFAULT_SCHEMA_NAME_PREFIX=your-schema-name-here
